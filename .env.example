# Copy to .env and edit. Sourced by the Makefile.
# Do not commit .env (it's gitignored).

# AWS profile (set to your admin profile name)
AWS_PROFILE=default

# AWS region for the cluster and the Pulumi state bucket
AWS_REGION=us-west-2

# Pulumi state bucket name (S3, project-scoped layout).
# Leave blank to auto-derive on first 'make bootstrap-state-bucket':
#   eks-pulumi-state-<account-id>-<region>
# Override here only if you want a custom name.
PULUMI_STATE_BUCKET=

# Pulumi stack name. 'main' is a base, not an environment.
STACK=main
